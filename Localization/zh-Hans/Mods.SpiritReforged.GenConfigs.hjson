UI: {
	Min: 全部最小
	MinDescription:
		'''
		将所有配置项设置为最能减少生成的值。
		因此，“最大树木”会被设为最小值，
		但“树木几率（1/x）”会被设为最大值。
		'''
	Max: 全部最大
	MaxDescription:
		'''
		将所有配置项设置为最能增加生成的值。
		因此，“最大树木”会被设为最大值，
		但“树木几率（1/x）”会被设为最小值。
		'''
	Preset: 预设：
	NoPresets: （无预设）
	None: 无
	Reset: 重置
	ResetAll: 重置全部
	Prior: 上一个：
	Next: 下一个：
	True: 启用
	False: 禁用
	Total: "{0}总计"
	CustomPresetTooltip: 这是一个自定义预设！
	Create: 保存为自定义预设
	CantSave: （你无法保存默认预设）
	Load: 加载自定义预设
	HoverDescription: 打开以配置来自魂灵新魄的世界生成的具体方面。
}

Pages: {
	Savanna: {
		Name: "{$Ecotones.SavannaEcotone}"
		Description: 控制稀树平原过渡带生成的具体方面。

		Presets: {
			Domesticated: {
				Name: "[i:224] 驯化"
				Tooltip: 一个更有生活气息的热带草原，更多的罐子，更少的野生动物.
			}

			Infested: {
				Name: "[i:SpiritReforged/TermiteJar] 虫患"
				Tooltip: 哎呀！全是白蚁！树木可能很难找到。
			}

			Bumpy: {
				Name: "[i:SpiritReforged/Drypowder] 崎岖"
				Tooltip: 注意脚下！狂野的稀树平原中遍布坑洼和丘陵。
			}
		}

		Members: {
			OverSpawn: {
				DisplayName: "[i:27] 覆盖生成点"
				Tooltip: 决定稀树平原是否在生成点生成，类似于“savanna”种子。
			}

			Steps: {
				DisplayName: "[i:SpiritReforged/DrywoodPlatformItem] 阶梯"
				Tooltip: 稀树平原生成的平坦阶梯数量。
			}

			CampsiteChance: {
				DisplayName: "[i:966] 营地几率"
				Tooltip: 营地生成的几率的分母（1/x）。
			}

			BaseTreeChance: {
				DisplayName: "[i:27] 合金欢树几率"
				Tooltip:
					'''
					特定物块上生成树木的几率的分母（1/x）。
					此几率会不断增加，直至树木被放置，然后重置。
					'''
			}

			PotChance: {
				DisplayName: "[i:31] 罐子几率"
				Tooltip:
					'''
					装饰时生成罐子的几率的分母（1/x）。
					这不会覆盖物块，因此当值为1并不会在每个物块上都放置罐子。
					'''
			}

			TermiteChance: {
				DisplayName: "[i:SpiritReforged/TermiteJar] 白蚁几率"
				Tooltip: 装饰时生成蚁丘的几率的分母（1/x）。
			}
		}
	}

	SaltFlats: {
		Name: "{$Ecotones.SaltFlatsEcotone}"
		Description: 控制盐滩过渡带生成的具体方面。

		Presets: {
			SunkenRuin: {
				Name: "[i:SpiritReforged/CobbledBrickItem] 沉没遗迹"
				Tooltip: 古老文明的遗迹已被冲蚀殆尽。
			}

			BlankCanvas: {
				Name: "[i:SpiritReforged/GlidingItem] 空白画布"
				Tooltip: 一片空无一物、无尽的映像展现在你面前。
			}

			Dessicated: {
				Name: "[i:1274] 干燥"
				Tooltip: 一滴水也看不见。所有的树木都已枯萎。
			}
		}

		Members: {
			OverSpawn: {
				DisplayName: "[i:27] 覆盖生成点"
				Tooltip: 决定盐滩是否在生成点生成，类似于“salt”种子。
			}

			RuinQty: {
				DisplayName: "[i:SpiritReforged/CalmingBellItem] 盐滩废墟"
				Tooltip: 放置的盐滩废墟数量的上限。并非所有都会放置。
			}

			LakeRadius: {
				DisplayName: "[i:206] 湖泊半径"
				Tooltip: 盐滩湖泊的半径。更大的半径对应更大的湖泊。
			}

			CaveRadius: {
				DisplayName: "[i:SpiritReforged/SaltWallItem] 洞穴半径"
				Tooltip: 盐滩洞穴的半径。更大的半径对应更大的洞穴。
			}

			MaxSteps: {
				DisplayName: "[i:SpiritReforged/SaltBlockReflectiveItem] 最大段数"
				Tooltip: 盐滩中反射盐滩平原的最大数量。
			}

			StupaChance: {
				DisplayName: "[i:SpiritReforged/StoneStupasItem] 佛塔几率"
				Tooltip:
					'''
					装饰时生成石质佛塔罐子的几率的分母（1/x）。
					这不会覆盖物块，因此值为1并不会在每个物块上都放置罐子。
					'''
			}

			TreeChance: {
				DisplayName: "[i:27] 枯树几率"
				Tooltip:
					'''
					特定物块上生成树木的几率的分母（1/x）。
					此几率会不断增加，直至树木被放置，然后重置。
					'''
			}
		}
	}

	Surface: {
		Name: 地表
		Description: 控制魂灵新魄对地表的补充和编辑的具体方面。

		Presets: {
			Whimsical: {
				Name: "[i:SpiritReforged/MidnightApple] 奇想"
				Tooltip: 巨大的繁茂洞穴，连绵起伏的星草山丘，宁静的麦田……能出什么差错呢？
			}

			Treacherous: {
				Name: "[i:SpiritReforged/LeatherBackpack] 险恶"
				Tooltip: 巨大的峡谷点缀着这里的风景。不要向下看！
			}
		}

		Members: {
			HalfWidth: {
				DisplayName: "[i:133] （峡谷）半宽"
				Tooltip: 控制峡谷隆起部分的半宽，前提是该部分足够接近地表。
			}

			MaxDepth: {
				DisplayName: "[i:133] （峡谷）最大深度"
				Tooltip: 控制峡谷的最大深度。
			}

			SizeMultiplier: {
				DisplayName: "[i:126] （喀斯特）尺寸倍率"
				Tooltip: 喀斯特地貌所有挖掘行为的尺寸倍率。
			}

			FieldSize: {
				DisplayName: "[i:SpiritReforged/BotanistHat] （稻草人）麦田尺寸"
				Tooltip: 控制稻草人麦田的宽度。
			}

			ButterflyCountMax: {
				DisplayName: "[i:SpiritReforged/ButterflyStaff] （蝴蝶圣地）最大数量"
				Tooltip: 可能被放置的蝴蝶圣地的最大数量。可能不会全部放置。
			}

			HeroChance: {
				DisplayName: "[i:SpiritReforged/HerosMemorialStatueItem] （英雄纪念碑） 生成几率"
				Tooltip: 英雄纪念碑生成的几率的分母（1/x）。
			}

			MaxStargrassCount: {
				DisplayName: "[i:SpiritReforged/StarPowder] （星草）区域数量"
				Tooltip: 可能被放置的星草区域的最大数量。可能不会全部放置，或可能会重叠。
			}
		}
	}

	Ocean: {
		Name: 海洋
		Description: 控制魂灵新魄翻新的海洋的具体方面。

		Presets: {
			KelpForest: {
				Name: "[i:SpiritReforged/Kelp] 海带森林"
				Tooltip: 从海岸就能看到成片的海带！
			}

			Volcanic: {
				Name: "[i:SpiritReforged/GravelItem] 火山"
				Tooltip: 多石、岩浆的海洋，几乎没有植物。
			}
		}

		Members: {
			WaterChestCount: {
				DisplayName: "[i:1298] 水中箱最大数量"
				Tooltip: 海洋中可能被放置的水中箱的最大数量。通常不会全部放置。
			}

			SunkenTreasureCount: {
				DisplayName: "[i:SpiritReforged/SunkenTreasure] 沉没的宝藏最大数量"
				Tooltip: 海洋中可能被放置的沉没的宝藏的最大数量。通常不会全部放置。
			}

			SandDepth: {
				DisplayName: "[i:169] 沙子深度"
				Tooltip: 海洋下方的沙子能深入地下多远。
			}

			SandRange: {
				DisplayName: "[i:169] 沙子范围"
				Tooltip: 海洋中沙子深度的随机添加范围的上限。
			}

			CoralLowChance: {
				DisplayName: "[i:275] 珊瑚几率（低层）"
				Tooltip: 珊瑚在海洋较低梯级生成的几率的分母（1/x）。
			}

			CoralHighChance: {
				DisplayName: "[i:275] 珊瑚几率（高层）"
				Tooltip: 珊瑚在海洋最高梯级生成的几率的分母（1/x）。
			}

			DecorLowChance: {
				DisplayName: "[i:4090] 装饰几率（低层）"
				Tooltip: 装饰物在海洋较低梯级生成的几率的分母（1/x）。
			}

			DecorHighChance: {
				DisplayName: "[i:4090] 装饰几率（高层）"
				Tooltip: 装饰物在海洋最高梯级生成的几率的分母（1/x）。
			}

			KelpChance: {
				DisplayName: "[i:SpiritReforged/Kelp] 海带几率"
				Tooltip: 海带在海洋生成的几率的分母（1/x）。
			}

			KelpMaxHeight: {
				DisplayName: "[i:SpiritReforged/Kelp] 海带高度"
				Tooltip: 海带可生成的最大高度（以格为单位）。
			}

			GravelMultiplier: {
				DisplayName: "[i:SpiritReforged/GravelItem] 砾石尺寸倍率"
				Tooltip: 海洋砾石区域（包括岩浆石）尺寸的修正值。
			}

			Shape: {
				DisplayName: "[i:4460] 海洋形状"
				Tooltip: 海洋呈现的形状。
			}
		}
	}

	Pots: {
		Name: 罐子
