	Ziggurat: {
		Name: 庙塔
		Description: 控制庙塔和其内容的具体方面。

		Members: {
			UsedWidth: {
				DisplayName: "[i:SpiritReforged/RedSandstoneSlabItem] 宽度"
				Tooltip:
					'''
					用于确定庙塔大小的宽度，不一定是实际宽度。
					高于默认值的值会强制庙塔生成在金字塔之上，否则它可能根本无法生成。
					'''
			}

			UsedHeight: {
				DisplayName: "[i:SpiritReforged/RedSandstoneSlabItem] 高度"
				Tooltip:
					'''
					用于确定庙塔大小的高度，不一定是实际高度。
