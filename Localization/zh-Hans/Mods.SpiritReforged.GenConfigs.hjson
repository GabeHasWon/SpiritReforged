			}

			StuffedScale: {
				DisplayName: "[i:SpiritReforged/StuffedPotsItem] 填充罐子比例"
				Tooltip: 填充罐子尝试生成的次数的倍率。
			}

			WormScale: {
				DisplayName: "[i:SpiritReforged/WormPotItem] 蠕虫罐子比例"
