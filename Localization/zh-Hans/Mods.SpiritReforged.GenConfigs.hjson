			}

			PlatterScale: {
				DisplayName: "[i:SpiritReforged/SilverPlattersItem] 银制托盘比例"
				Tooltip: 银制托盘尝试生成的次数的倍率。
			}

			AetherScale: {
				DisplayName: "[i:SpiritReforged/AetherShipmentItem] 以太货物比例"
