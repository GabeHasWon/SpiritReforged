				Tooltip: 控制稻草人麦田的宽度。
			}

			ButterflyCountMax: {
				DisplayName: "[i:SpiritReforged/ButterflyStaff] （蝴蝶圣地）最大数量"
				Tooltip: 可能被放置的蝴蝶圣地的最大数量。可能不会全部放置。
			}

			HeroChance: {
				DisplayName: "[i:SpiritReforged/HerosMemorialStatueItem] （英雄纪念碑）生成几率"
				Tooltip: 英雄纪念碑生成的几率的分母（1/x）。
			}

			MaxStargrassCount: {
				DisplayName: "[i:SpiritReforged/StarPowder] （星草）区域数量"
				Tooltip: 可能被放置的星草区域的最大数量。可能不会全部放置，或可能会重叠。
			}

			ReforgedCaveWeight: {
				DisplayName: "[i:30] （洞穴）自定义权重"
				Tooltip: 魂灵新魄的自定义洞穴替代原版“山洞”生成的权重。
			}
		}
	}

