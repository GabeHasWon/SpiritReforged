			}

			UpsideDownScale: {
				DisplayName: "[i:SpiritReforged/UpsideDownPotItem] 倒吊罐比例"
				Tooltip: 倒吊罐尝试生成的次数的倍率。
			}

			BoulderScale: {
				DisplayName: "[i:SpiritReforged/RollingPotsItem] 滚动罐子比例"
				Tooltip: 滚动罐子尝试生成的次数的倍率。
			}

			PicnicScale: {
				DisplayName: "[i:SpiritReforged/WickerBasketsItem] 野餐篮比例"
				Tooltip: 野餐篮尝试生成的次数的倍率。
			}

			StackScale: {
				DisplayName: "[i:SpiritReforged/PotsCavernItem] 堆叠比例"
				Tooltip: 堆叠罐子尝试生成的次数的倍率。
			}

			UncommonScale: {
				DisplayName: "[i:SpiritReforged/BiomePotsGraniteItem] 不常见比例"
				Tooltip: 不常见的罐子尝试生成的次数的倍率。
			}

			ZenithScale: {
				DisplayName: "[i:SpiritReforged/ZenithPotsItem] 天顶罐子比例"
				Tooltip: 天顶世界中天顶罐子尝试生成的次数的倍率。
			}
		}
	}

	Caves: {
		Name: 洞穴
		Description: 控制杂项洞穴补充内容。

		Members: {
			SignChance: {
				DisplayName: "[i:171] （房屋）标牌几率"
				Tooltip: 地下小屋中标牌生成的几率的分母（1/x）。
			}

			MannequinChance: {
				DisplayName: "[i:498] （房屋）人体模型几率"
				Tooltip: 地下小屋中人体模型生成的几率的分母（1/x）。
			}

			LoomChance: {
				DisplayName: "[i:332] （房屋）织布机几率"
				Tooltip: 地下小屋成为“织布机小屋”（会添加旗帜和织布机）的几率的分母（1/x）。
			}

			RareSignChance: {
				DisplayName: "[i:3617] （房屋）稀有标牌比率"
				Tooltip: 地下标牌出现稀有信息的几率的分母（1/x）。
			}

			CartSpawnRate: {
				DisplayName: "[i:13]（装饰）矿车比率"
				Tooltip: 世界中生成的矿石矿车最大数量的倍率。
			}

			BoomshroomRate: {
				DisplayName: "[i:SpiritReforged/BoomShroom] （装饰）蘑菇比率"
				Tooltip: 世界中生成的爆炸蘑菇最大数量的倍率。
			}

			CovesSpawnRate: {
				DisplayName: "[i:2291] （小湾）倍率"
				Tooltip: 
					'''
					世界中生成的钓鱼小湾最大数量的倍率。
					这可能会与其他生成结构的模组产生冲突。
					'''
			}

			NeonMossChance: {
				DisplayName: "[i:SpiritReforged/FlaskRadon] （氖苔藓）自定义苔藓几率"
				Tooltip: 选中魂灵新魄的自定义发光苔藓而非原版苔藓的几率（x/6）。
			}
		}

		Presets: {
			Inhabited: {
				Name: "[i:498] 曾有人迹"
				Tooltip: 地下各处都有友好探险者的踪迹……他们后来怎样了？
			}
		}
	}
}

Enums: {
	OceanShape: {
		Default: {
			DisplayName: 原版
			Tooltip: 原版默认的海洋生成。这会禁用大部分魂灵新魄的改动。
		}

		SlantedSine: {
			DisplayName: 倾斜正弦
			Tooltip: 一种修改后的形状，其中海洋由倾斜的正弦波定义。
		}

		Piecewise: {
			DisplayName: 分段
			Tooltip: 一个更复杂的分段函数定义了海洋的形状。
		}

		Piecewise_M: {
			DisplayName: 分段（M）
			Tooltip: 分段函数修改后的版本，具有略微不同的斜率。
		}

		Piecewise_V: {
			DisplayName: 魂灵新魄
			Tooltip: 分段预设的最终版本，包含各种微小修改。
		}
	}
}
